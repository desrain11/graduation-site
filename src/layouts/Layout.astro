---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
	/** 详情页开启软导航：项目间切换只替换内容区，固定区域不闪烁 */
	clientRouter?: boolean;
}

const { clientRouter = false } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/image/ui/FiLogo.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>Yunfei Hu — Academic Portfolio</title>
		<meta name="description" content="Academic portfolio of Yunfei (Fia) Hu — Industrial Design Master, Eindhoven University of Technology, 2024-2026." />
		{clientRouter && <ClientRouter />}
		<script is:inline>
			// 带 hash 深链进入主页时先隐藏，待翻页引擎定位后再显示，避免闪现封面
			if (window.location.hash && window.location.pathname === '/') {
				document.documentElement.setAttribute('data-boot-hidden', '');
			}
		</script>
		<style is:inline>
			html[data-boot-hidden] body { visibility: hidden; }
		</style>
	</head>
	<body>
		<slot />
	</body>
</html>
