---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar.astro';
import { formatProjectDate, getEaCode, getProjectsByCategory, getSectionBlocks, renderInline } from '../lib/content';
import type { Project } from '../lib/content';

const { main, course, extracurricular } = getProjectsByCategory();

// 文字版块：PI&V 合并为单页（PIV.txt，Vision→Manifesto→Identity 结构）
const textPages = [
	{ id: 'piv', heading: 'PI&V', file: 'PIV', blocks: getSectionBlocks('PIV') },
];
const tailTextPages = [
	{ id: 'expertise', heading: 'Expertise Areas.', file: 'expertise-areas', blocks: getSectionBlocks('expertise-areas') },
	{ id: 'development', heading: 'Development.', file: 'development', blocks: getSectionBlocks('development') },
];

const coverMenu = [
	{ label: 'PI&V', target: 'piv' },
	{ label: 'Project', target: 'project-main' },
	{ label: 'Expertise Areas', target: 'expertise' },
	{ label: 'Development', target: 'development' },
	{ label: 'Contract', target: 'contract' },
];

const projectPages: { id: string; projects: Project[]; useDisplayTitle: boolean }[] = [
	{ id: 'project-main', projects: main, useDisplayTitle: true },
	{ id: 'project-course', projects: course, useDisplayTitle: false },
	{ id: 'project-extracurricular', projects: extracurricular, useDisplayTitle: false },
];

const contactCards = [
	{ id: 'wechat', title: 'Wechat', detail: 'blueowl_fifi', qr: '/contact/QR-Wechat.svg', cover: '/contact/Cover-Wechat.svg' },
	{ id: 'email', title: 'Email', detail: 'fiahu301@gmail.com', qr: '/contact/QR-Email.svg', cover: '/contact/Cover-Email.svg', href: 'mailto:fiahu301@gmail.com' },
	{ id: 'linkedin', title: 'Linkedin', detail: 'yunfei-fia-hu', qr: '/contact/QR-Linkedin.svg', cover: '/contact/Cover-Linkedin.svg', href: 'https://www.linkedin.com/in/yunfei-fia-hu-813b8b2b0/' },
	{ id: 'dribbble', title: 'Dribbble', detail: 'Blueowlfifi', qr: '/contact/QR-Dribble.svg', cover: '/contact/Cover-Dribbble.svg', href: 'https://dribbble.com/Blueowlfifi' },
];

const socialLinks = [
	{ title: 'Wechat', icon: '/image/ui/Wechat.svg', href: undefined },
	{ title: 'Dribbble', icon: '/image/ui/Dribbble.svg', href: 'https://dribbble.com/Blueowlfifi' },
	{ title: 'Email', icon: '/image/ui/email.svg', href: 'mailto:fiahu301@gmail.com' },
	{ title: 'Linkedin', icon: '/image/ui/linkedin.svg', href: 'https://www.linkedin.com/in/yunfei-fia-hu-813b8b2b0/' },
];
---

<Layout>
	<div class="site is-cover" data-site>
		<Sidebar main={main} course={course} extracurricular={extracurricular} />

		<button class="menu-button" type="button" data-menu-button aria-label="Menu">
			<img src="/image/ui/Menu.svg" alt="" aria-hidden="true" />
		</button>

		<header class="topbar" data-topbar>
			<div class="view-toggle" data-view-toggle hidden>
				<button type="button" data-view-mode="grid" aria-label="Grid view"><img src="/image/ui/Grid.svg" alt="" aria-hidden="true" /></button>
				<button type="button" data-view-mode="row" aria-label="Row view"><img src="/image/ui/Column.svg" alt="" aria-hidden="true" /></button>
			</div>
			<div class="lang-switch" data-lang-switch>
				<img class="lang-en" src="/image/ui/EN.svg" alt="English" />
				<img class="lang-divider" src="/image/ui/CN_EN.svg" alt="" aria-hidden="true" />
				<button class="lang-cn" type="button" aria-label="中文版"><img src="/image/ui/CN.svg" alt="" aria-hidden="true" /></button>
				<span class="lang-tip" role="status" aria-live="polite">敬请期待</span>
			</div>
		</header>

		<div class="track" data-track>
			<!-- ====== 封面 ====== -->
			<section class="page page-cover" data-page="cover">
				<img class="cheese cheese-lt" src="/image/cover/Cheese%20Hole%20LT.svg" alt="" aria-hidden="true" />
				<img class="cheese cheese-rt" src="/image/cover/Cheese%20Hole%20RT.svg" alt="" aria-hidden="true" />
				<img class="cheese cheese-lb" src="/image/cover/Cheese%20Hole%20LB.svg" alt="" aria-hidden="true" />
				<img class="cheese cheese-rb" src="/image/cover/Cheese%20Hole%20RB.svg" alt="" aria-hidden="true" />

				<div class="cover-inner">
					<div class="cover-top">
						<img class="cover-title" src="/image/cover/YUNFEI%20HU..svg" alt="YUNFEI HU." />
						<div class="cover-info">
							<h2>ACADEMIC PORTFOLIO</h2>
							<div class="cover-info-sub">
								<p>Industrial Design · Master · 2024-2026</p>
								<p>Eindhoven University of Technology</p>
							</div>
						</div>
					</div>

					<img class="cover-photo" src="/image/cover/photo.svg" alt="Portrait of Yunfei Hu" />

					<nav class="cover-menu" aria-label="Sections">
						{coverMenu.map((item) => (
							<button class="cover-menu-row" type="button" data-cover-link data-nav-target={item.target}>
								<span>{item.label}</span>
								<img class="cover-menu-star" src="/image/ui/Star_B.svg" alt="" aria-hidden="true" />
							</button>
						))}
					</nav>

					<div class="cover-corner">
						<img class="cover-rat" src="/image/cover/RatOnly.svg" alt="" aria-hidden="true" />
						<div class="lang-switch cover-lang" data-lang-switch>
							<img class="lang-en" src="/image/ui/EN.svg" alt="English" />
							<img class="lang-divider" src="/image/ui/CN_EN.svg" alt="" aria-hidden="true" />
							<button class="lang-cn" type="button" aria-label="中文版"><img src="/image/ui/CN.svg" alt="" aria-hidden="true" /></button>
							<span class="lang-tip" role="status">敬请期待</span>
						</div>
						<div class="cover-socials" aria-label="Social links">
							{socialLinks.map((social) =>
								social.href
									? <a href={social.href} target={social.href.startsWith('http') ? '_blank' : undefined} rel="noreferrer" title={social.title}><img src={social.icon} alt={social.title} /></a>
									: <span title={social.title}><img src={social.icon} alt={social.title} /></span>
							)}
						</div>
					</div>
				</div>
			</section>

			<div class="page-gap"></div>

			<!-- ====== PI&V（Vision → Manifesto → Identity，单页） ====== -->
			{textPages.map((page) => (
				<>
					<section class="page page-content" data-page={page.id}>
						<div class="page-scroll" data-scroll>
							<div class="page-body text-body">
								<h2 class="page-heading">{page.heading}</h2>
								<div class="text-columns">
									{page.blocks.length > 0
										? page.blocks.map((block) => (
											block.type === 'hr' ? <hr class="text-rule" />
											: block.type === 'h2' ? <h3 class="text-h2" set:html={renderInline(block.text)} />
											: block.type === 'h3' ? <h4 class="text-h3" set:html={renderInline(block.text)} />
											: block.type === 'quote' ? <blockquote class="text-quote" set:html={renderInline(block.text)} />
											: block.type === 'subhead' ? <p class="text-subhead" set:html={renderInline(block.text)} />
											: <p set:html={renderInline(block.text)} />
										))
										: <p class="placeholder-note">（内容待填写：public/content/{page.file}.txt）</p>}
								</div>
							</div>
						</div>
					</section>
					<div class="page-gap"></div>
				</>
			))}

			<!-- ====== Project 三个分类页 ====== -->
			{projectPages.map((projectPage) => (
				<>
					<section class="page page-content" data-page={projectPage.id}>
						<div class="page-scroll" data-scroll>
							<div class="page-body">
								<div class="project-grid" data-project-grid>
									{projectPage.projects.map((project) => (
										<a class="project-card" href={`/project/${project.slug}/`}>
											<span class="project-card-media">
												<img src={project.coverImage} alt={`${project.shortTitle} cover`} loading="lazy" draggable="false" />
											</span>
											<span class="project-card-bar">
												<span class="ea-strip" aria-hidden="true">
													{project.info.eaInvolved.map((ea) => <i class={`ea-${getEaCode(ea)}`} title={ea}></i>)}
												</span>
												<strong class="project-card-title">{projectPage.useDisplayTitle ? project.displayTitle : project.shortTitle}</strong>
												<span class="project-card-meta">
													<small>{formatProjectDate(project.info.time)}</small>
													<span class="project-card-more">+ <u>More</u></span>
												</span>
											</span>
										</a>
									))}
									{projectPage.projects.length === 0 && <p class="placeholder-note">（暂无项目：请在 Info.txt 中填写对应 Category）</p>}
								</div>
							</div>
						</div>
					</section>
					<div class="page-gap"></div>
				</>
			))}

			<!-- ====== Expertise / Development ====== -->
			{tailTextPages.map((page) => (
				<>
					<section class="page page-content" data-page={page.id}>
						<div class="page-scroll" data-scroll>
							<div class="page-body text-body">
								<h2 class="page-heading">{page.heading}</h2>
								<div class="text-columns">
									{page.blocks.length > 0
										? page.blocks.map((block) => (
											block.type === 'hr' ? <hr class="text-rule" />
											: block.type === 'h2' ? <h3 class="text-h2" set:html={renderInline(block.text)} />
											: block.type === 'h3' ? <h4 class="text-h3" set:html={renderInline(block.text)} />
											: block.type === 'quote' ? <blockquote class="text-quote" set:html={renderInline(block.text)} />
											: block.type === 'subhead' ? <p class="text-subhead" set:html={renderInline(block.text)} />
											: <p set:html={renderInline(block.text)} />
										))
										: <p class="placeholder-note">（内容待填写：public/content/{page.file}.txt）</p>}
								</div>
							</div>
						</div>
					</section>
					<div class="page-gap"></div>
				</>
			))}

			<!-- ====== Contract ====== -->
			<section class="page page-content" data-page="contract">
				<div class="page-scroll" data-scroll>
					<div class="page-body contract-body">
						<div class="contact-cards">
							<span class="scratch-hint" data-scratch-hint aria-hidden="true">
								<span class="scratch-hint-text">Clean for QR</span>
								<svg class="scratch-hint-arrow" viewBox="0 0 24 32" fill="none" aria-hidden="true"><path d="M14 2c-6 6-5 16-2 26m0 0-5-6m5 6 6-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
							</span>
							{contactCards.map((card) => (
								<article class="contact-card">
									<h3>{card.title}</h3>
									<div class="scratch-card" data-scratch-card data-cover-src={card.cover}>
										<img class="scratch-qr" src={card.qr} alt={`${card.title} QR code`} draggable="false" />
										<canvas class="scratch-cover" data-scratch-cover></canvas>
									</div>
									{card.href
										? <a class="contact-detail" href={card.href} target="_blank" rel="noreferrer">{card.detail}</a>
										: <p class="contact-detail">{card.detail}</p>}
								</article>
							))}
						</div>
						<p class="copyright">© 2026 Yunfei Hu. All rights reserved.</p>
					</div>
				</div>
			</section>
		</div>

		<img class="rat-scrollbar" data-rat src="/image/ui/littleRat.svg" alt="" aria-hidden="true" hidden />
		<span class="flip-hint" data-flip-hint aria-hidden="true"></span>
	</div>

	<script>
		// ======== 元素引用 ========
		const site = document.querySelector('[data-site]');
		const track = document.querySelector('[data-track]');
		const pages = Array.from(track.querySelectorAll('.page'));
		const ids = pages.map((page) => page.dataset.page);
		const rat = document.querySelector('[data-rat]');
		const viewToggle = document.querySelector('[data-view-toggle]');
		const flipHint = document.querySelector('[data-flip-hint]');

		let active = 0;
		let flipping = false;
		let overscroll = 0;
		let overscrollTimer;
		const FLIP_MS = 720;

		const GAP = Number.parseFloat(getComputedStyle(document.documentElement).getPropertyValue('--page-gap')) || 140;
		const THRESHOLD = 72;  // 拖出约 72px 即翻页（对应设计稿示意的提示条高度）
		const RUBBER_K = 240;  // 橡皮筋阻力系数，越小越省力

		const pageTop = (index) => pages[index].offsetTop;

		function setTrack(y, animate) {
			track.style.transition = animate ? `transform ${FLIP_MS}ms cubic-bezier(0.22, 0.9, 0.3, 1)` : 'none';
			track.style.transform = `translateY(${-y}px)`;
		}

		function updateSidebarState() {
			const id = ids[active];
			const groupOf = {
				piv: 'piv',
				'project-main': 'project', 'project-course': 'project', 'project-extracurricular': 'project',
				expertise: 'expertise', development: 'development', contract: 'contract',
			};
			document.querySelectorAll('[data-nav-group]').forEach((group) => {
				group.classList.toggle('is-open', group.dataset.navGroup === groupOf[id]);
			});
			document.querySelectorAll('.nav-sub[data-nav-target]').forEach((sub) => {
				sub.classList.toggle('is-active', sub.dataset.navTarget === id);
			});
			document.querySelectorAll('[data-nav-subgroup]').forEach((subgroup) => {
				subgroup.classList.toggle('is-open', subgroup.dataset.navSubgroup === id);
			});
		}

		function goTo(index, animate = true) {
			const target = Math.max(0, Math.min(pages.length - 1, index));
			active = target;
			overscroll = 0;
			if (flipHint) flipHint.style.opacity = '0';
			flipping = animate;
			setTrack(pageTop(active), animate);
			site.classList.toggle('is-cover', ids[active] === 'cover');
			history.replaceState(null, '', ids[active] === 'cover' ? window.location.pathname : `#${ids[active]}`);
			updateSidebarState();
			updateViewToggle();
			window.setTimeout(() => {
				flipping = false;
				updateRat();
			}, animate ? FLIP_MS : 0);
		}

		// ======== 阻尼翻页 ========
		function setHint(direction, progress) {
			if (direction === 0) { flipHint.style.opacity = '0'; return; }
			flipHint.textContent = direction > 0 ? 'Next Page' : 'Last Page';
			flipHint.style.opacity = String(Math.min(1, progress));
		}

		function springBack() {
			overscroll = 0;
			setHint(0);
			setTrack(pageTop(active), true);
		}

		function handleDelta(deltaY, settleImmediately = false) {
			if (flipping) return;
			const scroller = pages[active].querySelector('[data-scroll]');

			if (scroller) {
				const atTop = scroller.scrollTop <= 0;
				const atBottom = scroller.scrollTop + scroller.clientHeight >= scroller.scrollHeight - 1;
				if ((deltaY > 0 && !atBottom) || (deltaY < 0 && !atTop)) {
					scroller.scrollTop += deltaY;
					if (overscroll !== 0) springBack();
					return;
				}
			}

			const direction = deltaY > 0 ? 1 : -1;
			const isEdge = (direction > 0 && active === pages.length - 1) || (direction < 0 && active === 0);
			if (isEdge) return;

			if (Math.sign(overscroll) !== direction && overscroll !== 0) overscroll = 0;
			overscroll += deltaY;

			// 橡皮筋：拖得越多阻力越大，最多拖出一个留白的距离
			const eased = GAP * (1 - 1 / (1 + Math.abs(overscroll) / RUBBER_K));
			setTrack(pageTop(active) + direction * eased, false);
			setHint(direction, eased / THRESHOLD);

			if (eased > THRESHOLD) {
				goTo(active + direction);
				return;
			}

			window.clearTimeout(overscrollTimer);
			if (settleImmediately) return; // 触摸场景由 touchend 决定回弹
			overscrollTimer = window.setTimeout(springBack, 240);
		}

		window.addEventListener('wheel', (event) => {
			event.preventDefault();
			handleDelta(event.deltaY);
		}, { passive: false });

		let touchLastY = null;
		window.addEventListener('touchstart', (event) => {
			touchLastY = event.touches[0].clientY;
		}, { passive: true });
		window.addEventListener('touchmove', (event) => {
			if (touchLastY === null) return;
			event.preventDefault();
			const y = event.touches[0].clientY;
			handleDelta(touchLastY - y, true);
			touchLastY = y;
		}, { passive: false });
		window.addEventListener('touchend', () => {
			touchLastY = null;
			if (overscroll !== 0 && !flipping) springBack();
		});

		window.addEventListener('keydown', (event) => {
			if (event.key === 'PageDown') { event.preventDefault(); goTo(active + 1); }
			if (event.key === 'PageUp') { event.preventDefault(); goTo(active - 1); }
		});

		// ======== 网格 / 行模式切换（项目页；需在首次 goTo 前就绪） ========
		const PROJECT_PAGE_IDS = ['project-main', 'project-course', 'project-extracurricular'];
		const DEFAULT_VIEW_MODE = { 'project-main': 'grid', 'project-course': 'grid', 'project-extracurricular': 'row' };

		function getViewMode(pageId) {
			return sessionStorage.getItem(`fiahu:view:${pageId}`) ?? DEFAULT_VIEW_MODE[pageId];
		}

		function applyViewMode(pageId) {
			const grid = document.querySelector(`[data-page="${pageId}"] [data-project-grid]`);
			grid?.classList.toggle('is-row-mode', getViewMode(pageId) === 'row');
		}

		function updateViewToggle() {
			const id = ids[active];
			const isProjectPage = PROJECT_PAGE_IDS.includes(id);
			viewToggle.hidden = !isProjectPage;
			if (!isProjectPage) return;
			const mode = getViewMode(id);
			viewToggle.querySelectorAll('[data-view-mode]').forEach((button) => {
				button.classList.toggle('is-active', button.dataset.viewMode === mode);
			});
		}

		viewToggle.querySelectorAll('[data-view-mode]').forEach((button) => {
			button.addEventListener('click', () => {
				const id = ids[active];
				if (!PROJECT_PAGE_IDS.includes(id)) return;
				sessionStorage.setItem(`fiahu:view:${id}`, button.dataset.viewMode);
				applyViewMode(id);
				updateViewToggle();
			});
		});

		PROJECT_PAGE_IDS.forEach(applyViewMode);
		updateViewToggle();

		// ======== 导航 ========
		document.querySelectorAll('[data-cover-link], [data-nav-link]').forEach((link) => {
			link.addEventListener('click', (event) => {
				const target = link.dataset.navTarget;
				if (!target) return;
				event.preventDefault();
				document.body.classList.remove('menu-open');
				goTo(ids.indexOf(target));
			});
		});

		// 窄屏菜单按钮
		document.querySelector('[data-menu-button]')?.addEventListener('click', () => {
			document.body.classList.toggle('menu-open');
		});

		// 初始定位（支持 /#project-main 之类的深链；boot-hidden 在定位后移除避免闪封面）
		// is-static：深链返回时侧边栏/过渡全部保持静态，不播动画
		const initial = ids.indexOf(decodeURIComponent(window.location.hash.replace(/^#/, '')));
		if (initial > 0) {
			site.classList.add('is-static');
			goTo(initial, false);
			window.requestAnimationFrame(() => window.requestAnimationFrame(() => site.classList.remove('is-static')));
		} else {
			updateSidebarState();
		}
		document.documentElement.removeAttribute('data-boot-hidden');

		window.addEventListener('hashchange', () => {
			const target = ids.indexOf(decodeURIComponent(window.location.hash.replace(/^#/, '')));
			if (target >= 0 && target !== active) goTo(target);
		});

		window.addEventListener('resize', () => setTrack(pageTop(active), false));

		// ======== 中文版提示 ========
		document.querySelectorAll('.lang-cn').forEach((button) => {
			button.addEventListener('click', () => {
				const wrap = button.closest('[data-lang-switch]');
				wrap?.classList.add('is-tip-visible');
				window.setTimeout(() => wrap?.classList.remove('is-tip-visible'), 1600);
			});
		});

		// ======== 小老鼠滚动条 ========
		// littleRat.svg 为横向素材（默认头朝右）：
		// 下滑 rotate(90deg) 头朝下；上滑 rotate(-90deg) 头朝上；停靠左侧时水平。
		let ratParkedLeft = false;

		function updateRat(direction) {
			const scroller = pages[active].querySelector('[data-scroll]');
			if (ids[active] === 'cover' || !scroller) { rat.hidden = true; return; }
			rat.hidden = false;

			const scrollable = scroller.scrollHeight - scroller.clientHeight;
			const ratio = scrollable > 0 ? scroller.scrollTop / scrollable : 0;
			const travel = window.innerHeight * 0.7;
			const top = window.innerHeight * 0.14 + ratio * travel;
			rat.style.top = `${scrollable > 0 ? top : window.innerHeight * 0.12}px`;

			if (direction === 1) rat.dataset.heading = 'down';
			else if (direction === -1) rat.dataset.heading = 'up';
			else if (!rat.dataset.heading) rat.dataset.heading = 'down';
		}

		pages.forEach((page) => {
			const scroller = page.querySelector('[data-scroll]');
			if (!scroller) return;
			let lastTop = 0;
			scroller.addEventListener('scroll', () => {
				const direction = scroller.scrollTop > lastTop ? 1 : -1;
				lastTop = scroller.scrollTop;
				scroller.classList.toggle('is-scrolled', scroller.scrollTop > 0);
				if (!ratParkedLeft) updateRat(direction);
			}, { passive: true });
		});

		rat.addEventListener('click', () => {
			ratParkedLeft = !ratParkedLeft;
			rat.classList.toggle('is-parked', ratParkedLeft);
			if (!ratParkedLeft) updateRat();
		});

		updateRat();

		// ======== Contract 刮刮卡（封面图封层，刮开见 QR） ========
		// 提示状态机：刮开任意一张 → 提示消失；封层恢复后若一张都没刮开，5s 后提示渐入
		const scratchHint = document.querySelector('[data-scratch-hint]');
		const scratchCards = Array.from(document.querySelectorAll('[data-scratch-card]'));
		let hintTimer;

		function onScratchStateChange() {
			window.clearTimeout(hintTimer);
			const anyCleared = scratchCards.some((card) => card.classList.contains('is-cleared'));
			if (anyCleared) {
				scratchHint?.classList.add('is-hidden');
			} else {
				hintTimer = window.setTimeout(() => scratchHint?.classList.remove('is-hidden'), 5000);
			}
		}

		scratchCards.forEach((card) => {
			const canvas = card.querySelector('[data-scratch-cover]');
			if (!(canvas instanceof HTMLCanvasElement)) return;
			const context = canvas.getContext('2d', { willReadFrequently: true });
			if (!context) return;

			const coverImage = new Image();
			coverImage.src = card.dataset.coverSrc ?? '';
			let isScratching = false;
			let resetTimer;

			function drawCover() {
				const size = Math.max(1, Math.round(card.clientWidth));
				const pixelRatio = window.devicePixelRatio || 1;
				canvas.width = Math.round(size * pixelRatio);
				canvas.height = Math.round(size * pixelRatio);
				canvas.style.width = `${size}px`;
				canvas.style.height = `${size}px`;
				context.setTransform(pixelRatio, 0, 0, pixelRatio, 0, 0);
				context.globalCompositeOperation = 'source-over';
				context.clearRect(0, 0, size, size);
				if (coverImage.complete && coverImage.naturalWidth > 0) {
					context.drawImage(coverImage, 0, 0, size, size);
				} else {
					context.fillStyle = '#2c2c2c';
					context.fillRect(0, 0, size, size);
				}
				card.classList.remove('is-cleared');
				onScratchStateChange();
			}

			function scratchAt(event) {
				const rect = canvas.getBoundingClientRect();
				const x = event.clientX - rect.left;
				const y = event.clientY - rect.top;
				context.globalCompositeOperation = 'destination-out';
				context.beginPath();
				context.arc(x, y, 26, 0, Math.PI * 2);
				context.fill();
			}

			function clearedRatio() {
				const data = context.getImageData(0, 0, canvas.width, canvas.height).data;
				let transparent = 0;
				for (let i = 3; i < data.length; i += 4) if (data[i] < 16) transparent += 1;
				return transparent / (data.length / 4);
			}

			canvas.addEventListener('pointerdown', (event) => {
				event.preventDefault();
				isScratching = true;
				canvas.setPointerCapture(event.pointerId);
				scratchAt(event);
			});
			canvas.addEventListener('pointermove', (event) => { if (isScratching) scratchAt(event); });
			canvas.addEventListener('pointerup', (event) => {
				isScratching = false;
				if (canvas.hasPointerCapture(event.pointerId)) canvas.releasePointerCapture(event.pointerId);
				if (clearedRatio() >= 0.7) {
					card.classList.add('is-cleared');
					onScratchStateChange();
				}
				window.clearTimeout(resetTimer);
				resetTimer = window.setTimeout(drawCover, 15000); // 封层 15s 后恢复
			});
			coverImage.addEventListener('load', drawCover, { once: true });
			window.addEventListener('resize', drawCover);
			drawCover();
		});
	</script>
</Layout>

