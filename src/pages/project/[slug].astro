---
import Layout from '../../layouts/Layout.astro';
import Sidebar from '../../components/Sidebar.astro';
import { getProjectDetails, getProjectsByCategory, renderInline } from '../../lib/content';
import type { ProjectDetail } from '../../lib/content';

export function getStaticPaths() {
	return getProjectDetails().map((project) => ({
		params: { slug: project.slug },
		props: { project },
	}));
}

interface Props {
	project: ProjectDetail;
}

const { project } = Astro.props;
const { main, course, extracurricular } = getProjectsByCategory();

const backTarget = {
	main: { hash: 'project-main', label: 'Back to Project/Main' },
	course: { hash: 'project-course', label: 'Back to Project/Course' },
	extracurricular: { hash: 'project-extracurricular', label: 'Back to Project/Extracurricular' },
}[project.info.category];

// 元信息行：取 frontmatter（缺省回落到 Info.md）
const metaItems = [
	['Period', project.meta.period || project.info.time],
	['Type', project.meta.type || project.info.projectType],
	['Role', project.info.role],
	['Client', project.meta.client || project.info.client],
	['Team', project.meta.members],
	['Coach', project.meta.coach],
].filter(([, value]) => Boolean(value)) as [string, string][];

// 把正文与 References 分区：References 标题之后的块归入 refBlocks；正文不含该段
const refHeadingIndex = project.blocks.findIndex((b) => b.type === 'h2' && /^references$/i.test(b.text));
const bodyBlocks = refHeadingIndex >= 0 ? project.blocks.slice(0, refHeadingIndex) : project.blocks;
const refBlocks = refHeadingIndex >= 0
	? project.blocks.slice(refHeadingIndex + 1).filter((b) => b.type !== 'hr')
	: [];
const hasReferences = refBlocks.length > 0;

function getEaMarkerCode(item: string) {
	const prefix = item.match(/^\*\*([^*]+)\*\*/)?.[1]?.trim().toUpperCase();
	if (!prefix) return '';
	if (prefix.includes('C&A')) return 'ca';
	if (prefix.includes('T&R')) return 'tr';
	if (prefix.includes('U&S')) return 'us';
	if (prefix.includes('B&E')) return 'be';
	if (prefix.includes('MD&C')) return 'mdc';
	return '';
}
---

<Layout clientRouter>
	<div class="detail-site">
		<Sidebar currentSlug={project.slug} main={main} course={course} extracurricular={extracurricular} />

		<button class="menu-button" type="button" data-menu-button aria-label="Menu" transition:name="menu-button" transition:animate="none">
			<img src="/image/ui/Menu.svg" alt="" aria-hidden="true" />
		</button>

		<!-- 固定顶栏：返回 + 语言切换（与侧边栏 logo 顶部对齐，不随内容滚动） -->
		<header class="topbar" transition:name="detail-topbar" transition:animate="none">
			<a class="back-link" href={`/#${backTarget.hash}`}>
				<img src="/image/ui/Back.svg" alt="" aria-hidden="true" />
				<span>{backTarget.label}</span>
			</a>
			<div class="lang-switch" data-lang-switch>
				<img class="lang-en" src="/image/ui/EN.svg" alt="English" />
				<img class="lang-divider" src="/image/ui/CN_EN.svg" alt="" aria-hidden="true" />
				<button class="lang-cn" type="button" aria-label="中文版"><img src="/image/ui/CN.svg" alt="" aria-hidden="true" /></button>
				<span class="lang-tip" role="status" aria-live="polite">Browser translation is not available on this local page.</span>
			</div>
		</header>

		<div class="detail-top-fade" aria-hidden="true" transition:name="detail-fade" transition:animate="none"></div>

		<main class="detail-main">
			<h1 class="detail-heading">
				{project.dribbbleUrl
					? <a href={project.dribbbleUrl} target="_blank" rel="noreferrer" title="View this project on Dribbble">{project.displayTitle}.</a>
					: `${project.displayTitle}.`}
			</h1>
			{project.meta.subtitle && <p class="detail-subtitle">{project.meta.subtitle}</p>}

			<div class="detail-layout">
				<!-- 左栏：fig_in_web 图片，按编号顺序排列 -->
				{project.figures.length > 0 && (
					<aside class="detail-figures">
						{project.figures.map((figure) => (
							<figure>
								<button
									class="figure-zoom-trigger"
									type="button"
									data-figure-trigger
									data-figure-src={figure.src}
									data-figure-alt={figure.caption}
									aria-label={`Open ${figure.caption} in fullscreen`}
								>
									<img src={figure.src} alt={figure.caption} loading="lazy" />
								</button>
								<figcaption>{figure.caption}</figcaption>
							</figure>
						))}
					</aside>
				)}

				<article class="detail-body">
					{metaItems.length > 0 && (
						<dl class="detail-meta">
							{metaItems.map(([label, value]) => (
								<div><dt>{label}</dt><dd>{value}</dd></div>
							))}
						</dl>
					)}

					{bodyBlocks.map((block) => (
						block.type === 'hr' ? <hr class="text-rule" />
						: block.type === 'h2' ? <h2 class="text-h2" set:html={renderInline(block.text)} />
						: block.type === 'h3' ? <h3 class="text-h3" set:html={renderInline(block.text)} />
						: block.type === 'quote' ? <blockquote class:list={['text-quote', { 'is-nda-note': /non-disclosure agreement|nda/i.test(block.text) }]} set:html={renderInline(block.text)} />
						: block.type === 'subhead' ? <p class="text-subhead" set:html={renderInline(block.text)} />
						: block.type === 'list' ? <ul class="text-list">{block.items.map((item) => <li class:list={['text-list-item', getEaMarkerCode(item) && `marker-${getEaMarkerCode(item)}`]} set:html={renderInline(item)} />)}</ul>
						: <p set:html={renderInline(block.text)} />
					))}
					{bodyBlocks.length === 0 && (
						<p class="placeholder-note">（内容待填写：{project.projectDir}/03-ea-contribution/portfolio-content.md）</p>
					)}

					{hasReferences && (
						<section class="detail-references">
							<hr class="ref-divider" />
							<h2 class="ref-title">References</h2>
							{refBlocks.map((block) => (
								block.type === 'list'
									? <ul class="text-list">{block.items.map((item) => <li set:html={renderInline(item)} />)}</ul>
									: <p set:html={renderInline(block.type === 'para' ? block.text : '')} />
							))}
						</section>
					)}
				</article>
			</div>
		</main>
		<div class="figure-lightbox" data-figure-lightbox hidden aria-hidden="true">
			<div class="figure-lightbox-backdrop" data-figure-close></div>
			<div class="figure-lightbox-panel" role="dialog" aria-modal="true" aria-label="Fullscreen image preview">
				<button class="figure-lightbox-close" type="button" data-figure-close aria-label="Close fullscreen image preview">×</button>
				<img class="figure-lightbox-image" data-figure-lightbox-image src="" alt="" />
			</div>
		</div>
	</div>
</Layout>

<style is:global>
	.detail-site {
		min-height: 100dvh;
		background: var(--paper-texture) top center / 100% auto repeat-y fixed;
	}
	/* 非封面页：纹理上叠 50% 白底 */
	.detail-site::before {
		content: '';
		position: fixed;
		inset: 0;
		background: rgba(255, 255, 255, 0.5);
		pointer-events: none;
	}

	/* 详情页恢复原生滚动；滚动条占位恒定，长短内容不横移版面 */
	body:has(.detail-site) {
		overflow-y: auto;
		scrollbar-gutter: stable;
	}

	.detail-site .topbar {
		position: fixed;
		top: calc(48 * var(--u)); /* 与侧边栏 logo 顶部对齐 */
		left: 0;
		right: 0;
		height: calc(32 * var(--u));
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0 calc(56 * var(--u)) 0 calc(390 * var(--u));
		pointer-events: none;
		z-index: 40;
	}
	.detail-site .topbar > * { pointer-events: auto; }

	/* 返回：24 号字 + Back 图标，固定不随内容滚动 */
	.back-link {
		display: flex;
		align-items: center;
		gap: calc(12 * var(--u));
		font-size: calc(24 * var(--u));
		color: #333333;
		text-decoration: none;
	}
	.back-link img { display: block; width: calc(24 * var(--u)); height: calc(24 * var(--u)); }
	.back-link:hover span { text-decoration: underline; text-underline-offset: 3px; }

	.lang-switch {
		position: relative;
		display: flex;
		align-items: center;
		gap: calc(10 * var(--u));
		height: calc(24 * var(--u));
	}
	.lang-en { height: calc(17 * var(--u)); }
	.lang-divider { height: calc(24 * var(--u)); }
	.lang-cn { border: 0; background: none; padding: 0; cursor: pointer; opacity: 0.4; transition: opacity 160ms ease; }
	.lang-cn:hover { opacity: 0.8; }
	.lang-cn img { display: block; height: calc(20 * var(--u)); }
	.lang-tip {
		position: absolute;
		top: 130%;
		right: 0;
		background: #333333;
		color: #fff6d7;
		font-size: 12px;
		padding: 4px 10px;
		border-radius: 4px;
		white-space: nowrap;
		opacity: 0;
		pointer-events: none;
		transition: opacity 200ms ease;
	}
	.is-tip-visible .lang-tip { opacity: 1; }

	.menu-button {
		display: none;
		position: fixed;
		top: 20px;
		left: 20px;
		z-index: 70;
		border: 0;
		background: none;
		padding: 8px;
		cursor: pointer;
	}
	.menu-button img { display: block; width: 28px; }

	/* 顶部渐隐：与固定背景同纹理的遮挡条，向下滚动的内容在 16 内渐变隐去 */
	.detail-top-fade {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		height: calc(120 * var(--u));
		background:
			linear-gradient(rgba(255, 255, 255, 0.5), rgba(255, 255, 255, 0.5)),
			var(--paper-texture) top center / 100% auto repeat-y fixed;
		-webkit-mask-image: linear-gradient(to bottom, black calc(100% - 16 * var(--u)), transparent);
		mask-image: linear-gradient(to bottom, black calc(100% - 16 * var(--u)), transparent);
		pointer-events: none;
		z-index: 5;
	}

	.detail-main {
		position: relative;
		z-index: 1;
		padding:
			calc(120 * var(--u)) /* 与侧边栏 PI&V 顶部对齐 */
			calc(110 * var(--u))
			calc(100 * var(--u))
			calc(390 * var(--u));
	}

	.detail-heading {
		margin: 0 0 calc(40 * var(--u));
		text-align: right;
		font-size: calc(40 * var(--u));
		font-weight: 700;
		color: #333333;
	}
	.detail-heading a { text-decoration: none; }
	.detail-heading a:hover { text-decoration: underline; }

	.detail-subtitle {
		margin: calc(-28 * var(--u)) 0 calc(36 * var(--u));
		text-align: right;
		font-size: calc(18 * var(--u));
		font-style: italic;
		color: var(--color-ink-soft);
	}

	/* 左图右文两栏 */
	.detail-layout {
		display: grid;
		grid-template-columns: calc(340 * var(--u)) 1fr;
		column-gap: calc(48 * var(--u));
		align-items: start;
	}
	.detail-figures {
		display: flex;
		flex-direction: column;
		gap: calc(20 * var(--u));
		position: sticky;
		top: calc(120 * var(--u));
	}
	.detail-figures figure { margin: 0; }
	.figure-zoom-trigger {
		display: block;
		width: 100%;
		padding: 0;
		border: 0;
		background: none;
		cursor: zoom-in;
	}
	.detail-figures img { display: block; width: 100%; border-radius: 4px; }
	.detail-figures figcaption {
		margin-top: calc(6 * var(--u));
		font-size: calc(13 * var(--u));
		color: var(--color-ink-soft);
	}

	.detail-body > p {
		margin: 0 0 calc(18 * var(--u));
		font-size: calc(18 * var(--u));
		line-height: 1.55;
		text-align: justify;
		color: #333333;
	}
	.detail-body :global(strong) { font-weight: 700; }
	.detail-body :global(a) { color: #1c1812; text-underline-offset: 3px; }
	.detail-body :global(sup.cite-mark) { color: var(--color-muted); font-size: 0.7em; padding: 0 1px; }

	/* References：正文末尾，分割线区隔，40% #333 */
	.detail-references { margin-top: calc(36 * var(--u)); color: rgba(51, 51, 51, 0.4); }
	.ref-divider { margin: 0 0 calc(20 * var(--u)); border: 0; border-top: 1px solid rgba(51, 51, 51, 0.4); }
	.ref-title { margin: 0 0 calc(12 * var(--u)); font-size: calc(16 * var(--u)); font-weight: 700; }
	.detail-references p {
		margin: 0 0 calc(8 * var(--u));
		font-size: calc(13 * var(--u));
		line-height: 1.5;
		word-break: break-word;
	}
	.detail-references :global(a) { color: inherit; }

	/* 元信息表 */
	.detail-meta {
		margin: 0 0 calc(28 * var(--u));
		display: grid;
		grid-template-columns: max-content 1fr;
		column-gap: calc(20 * var(--u));
		row-gap: calc(6 * var(--u));
		font-size: calc(14 * var(--u));
	}
	.detail-meta > div { display: contents; }
	.detail-meta dt { color: var(--color-muted); }
	.detail-meta dd { margin: 0; color: #333333; }

	/* Markdown 块（与首页文字版块同款） */
	.text-h2 {
		margin: calc(30 * var(--u)) 0 calc(12 * var(--u));
		font-size: calc(22 * var(--u));
		font-weight: 700;
		color: #1c1812;
	}
	.text-h3 {
		margin: calc(20 * var(--u)) 0 calc(10 * var(--u));
		font-size: calc(19 * var(--u));
		font-weight: 700;
		color: #1c1812;
	}
	.text-subhead { margin: calc(14 * var(--u)) 0 calc(4 * var(--u)); font-weight: 700; color: #1c1812; }
	.text-quote {
		margin: calc(8 * var(--u)) 0 calc(18 * var(--u));
		padding-left: calc(16 * var(--u));
		border-left: calc(3 * var(--u)) solid rgba(51, 51, 51, 0.4);
		font-style: italic;
		color: #4a4438;
	}
	.text-quote.is-nda-note {
		font-size: calc(13 * var(--u));
		line-height: 1.5;
		color: rgba(51, 51, 51, 0.4);
		border-left-color: rgba(51, 51, 51, 0.24);
	}
	.text-rule { margin: calc(26 * var(--u)) 0; border: 0; border-top: 1px solid rgba(51, 51, 51, 0.18); }
	.text-list {
		margin: 0 0 calc(18 * var(--u));
		padding-left: calc(22 * var(--u));
		font-size: calc(18 * var(--u));
		line-height: 1.5;
		color: #333333;
	}
	.text-list li { margin-bottom: calc(6 * var(--u)); }
	.text-list-item.marker-ca,
	.text-list-item.marker-tr,
	.text-list-item.marker-us,
	.text-list-item.marker-be,
	.text-list-item.marker-mdc {
		list-style: none;
		position: relative;
		padding-left: calc(20 * var(--u));
	}
	.text-list-item.marker-ca::before,
	.text-list-item.marker-tr::before,
	.text-list-item.marker-us::before,
	.text-list-item.marker-be::before,
	.text-list-item.marker-mdc::before {
		content: '';
		position: absolute;
		left: 0;
		top: 0.58em;
		width: calc(9 * var(--u));
		height: calc(9 * var(--u));
		border-radius: 1px;
		transform: translateY(-50%);
	}
	.text-list-item.marker-ca::before { background: #b25656; }
	.text-list-item.marker-tr::before { background: #c1a053; }
	.text-list-item.marker-us::before { background: #6d9458; }
	.text-list-item.marker-be::before { background: #5667b2; }
	.text-list-item.marker-mdc::before { background: #9371a7; }

	.placeholder-note { color: var(--color-muted); font-style: italic; }

	.figure-lightbox {
		position: fixed;
		inset: 0;
		z-index: 90;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: calc(32 * var(--u));
	}
	.figure-lightbox[hidden] { display: none; }
	.figure-lightbox-backdrop {
		position: absolute;
		inset: 0;
		background: rgba(0, 0, 0, 0.6);
	}
	.figure-lightbox-panel {
		position: relative;
		z-index: 1;
		width: min(calc(1280 * var(--u)), 100%);
		max-height: 100%;
		display: flex;
		justify-content: center;
		align-items: flex-start;
	}
	.figure-lightbox-image {
		display: block;
		width: 100%;
		max-width: 100%;
		max-height: calc(100dvh - 64px);
		object-fit: contain;
		border-radius: 6px;
	}
	.figure-lightbox-close {
		position: absolute;
		top: calc(12 * var(--u));
		right: calc(12 * var(--u));
		z-index: 2;
		width: calc(40 * var(--u));
		height: calc(40 * var(--u));
		border: 0;
		border-radius: 999px;
		background: rgba(0, 0, 0, 0.45);
		color: #ffffff;
		font-size: calc(28 * var(--u));
		line-height: 1;
		cursor: pointer;
	}

	/* 窄屏：菜单按钮 + 图片收进文字流，与段落等宽 */
	@media (max-width: 900px) {
		.menu-button { display: block; }
		.detail-site .topbar { padding: 0 20px 0 64px; top: 18px; height: 28px; }
		.back-link { font-size: 16px; gap: 8px; }
		.back-link img { width: 18px; height: 18px; }
		.lang-switch { height: 22px; gap: 8px; }
		.lang-en { height: 15px; }
		.lang-divider { height: 22px; }
		.lang-cn img { height: 18px; }
		.detail-main { padding: 84px 24px 64px; }
		.detail-heading { font-size: 26px; }
		.detail-subtitle { font-size: 15px; margin-top: -12px; }
		.detail-layout { display: flex; flex-direction: column; gap: 20px; }
		.detail-figures { position: static; order: 2; }
		.detail-body { order: 1; }
		.detail-body > p, .text-list { font-size: 16px; }
		.text-quote.is-nda-note { font-size: 12px; }
		.figure-lightbox { padding: 16px; }
		.figure-lightbox-image { max-height: calc(100dvh - 32px); }
	}
</style>

<script>
	// ClientRouter 软导航后 DOM 被替换，每次 astro:page-load 重新绑定
	function initDetailPage() {
		document.querySelectorAll('.lang-cn').forEach((button) => {
			button.addEventListener('click', () => {
				const wrap = button.closest('[data-lang-switch]');
				wrap?.classList.add('is-tip-visible');
				window.setTimeout(() => wrap?.classList.remove('is-tip-visible'), 2200);
			});
		});

		document.querySelector('[data-menu-button]')?.addEventListener('click', () => {
			document.body.classList.toggle('menu-open');
		});

		const lightbox = document.querySelector('[data-figure-lightbox]');
		const lightboxImage = document.querySelector('[data-figure-lightbox-image]');
		if (!(lightbox instanceof HTMLElement) || !(lightboxImage instanceof HTMLImageElement)) return;

		const closeLightbox = () => {
			lightbox.hidden = true;
			lightbox.setAttribute('aria-hidden', 'true');
			document.body.style.overflow = '';
		};

		document.querySelectorAll('[data-figure-trigger]').forEach((trigger) => {
			trigger.addEventListener('click', () => {
				const src = trigger.getAttribute('data-figure-src');
				const alt = trigger.getAttribute('data-figure-alt') ?? '';
				if (!src) return;
				lightboxImage.src = src;
				lightboxImage.alt = alt;
				lightbox.hidden = false;
				lightbox.setAttribute('aria-hidden', 'false');
				document.body.style.overflow = 'hidden';
			});
		});

		lightbox.querySelectorAll('[data-figure-close]').forEach((node) => {
			node.addEventListener('click', closeLightbox);
		});

		document.addEventListener('keydown', (event) => {
			if (event.key === 'Escape' && !lightbox.hidden) closeLightbox();
		});
	}

	document.addEventListener('astro:page-load', initDetailPage);
</script>
