---
import Layout from '../../layouts/Layout.astro';
import Sidebar from '../../components/Sidebar.astro';
import { getProjectDetails, getProjectsByCategory } from '../../lib/content';
import type { ProjectDetail } from '../../lib/content';

export function getStaticPaths() {
	return getProjectDetails().map((project) => ({
		params: { slug: project.slug },
		props: { project },
	}));
}

interface Props {
	project: ProjectDetail;
}

const { project } = Astro.props;
const { main, course, extracurricular } = getProjectsByCategory();

const backTarget = {
	main: { hash: 'project-main', label: 'Back to Project/Main' },
	course: { hash: 'project-course', label: 'Back to Project/Course' },
	extracurricular: { hash: 'project-extracurricular', label: 'Back to Project/Extracurricular' },
}[project.info.category];

const figureByIndex = new Map(project.figures.map((figure) => [figure.index, figure]));

const escapeHtml = (value: string) =>
	value.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');

// 段落内的 figure~N 标记替换为 (Figure N)
const renderParagraph = (text: string) =>
	escapeHtml(text).replace(/figure\s*~\s*(\d+)/gi, '<em class="figure-ref">(Figure $1)</em>');
---

<Layout>
	<div class="detail-site">
		<Sidebar currentSlug={project.slug} main={main} course={course} extracurricular={extracurricular} />

		<button class="menu-button" type="button" data-menu-button aria-label="Menu">
			<img src="/image/ui/Menu.svg" alt="" aria-hidden="true" />
		</button>

		<!-- 固定顶栏：返回 + 语言切换（与侧边栏 logo 顶部对齐，不随内容滚动） -->
		<header class="topbar">
			<a class="back-link" href={`/#${backTarget.hash}`}>
				<img src="/image/ui/Back.svg" alt="" aria-hidden="true" />
				<span>{backTarget.label}</span>
			</a>
			<div class="lang-switch" data-lang-switch>
				<img class="lang-en" src="/image/ui/EN.svg" alt="English" />
				<img class="lang-divider" src="/image/ui/CN_EN.svg" alt="" aria-hidden="true" />
				<button class="lang-cn" type="button" aria-label="中文版"><img src="/image/ui/CN.svg" alt="" aria-hidden="true" /></button>
				<span class="lang-tip" role="status" aria-live="polite">敬请期待</span>
			</div>
		</header>

		<main class="detail-main">
			<h1 class="detail-heading">
				{project.dribbbleUrl
					? <a href={project.dribbbleUrl} target="_blank" rel="noreferrer" title="View this project on Dribbble">{project.displayTitle}.</a>
					: `${project.displayTitle}.`}
			</h1>

			<article class="detail-blocks">
				{project.blocks.map((block) => {
					const figures = block.figureRefs
						.map((index) => figureByIndex.get(index))
						.filter((figure) => Boolean(figure));
					return (
						<div class:list={['detail-row', { 'has-figures': figures.length > 0 }]}>
							{figures.length > 0 && (
								<div class="detail-figures">
									{figures.map((figure) => (
										<figure>
											<img src={figure.src} alt={figure.caption} loading="lazy" />
											<figcaption>{figure.caption}</figcaption>
										</figure>
									))}
								</div>
							)}
							<p set:html={renderParagraph(block.text)} />
						</div>
					);
				})}
				{project.blocks.length === 0 && (
					<p class="placeholder-note">（内容待填写：{project.projectDir}/03-ea-contribution/ea-contribution.txt）</p>
				)}
			</article>
		</main>
	</div>
</Layout>

<style is:global>
	.detail-site {
		min-height: 100dvh;
		background: var(--paper-texture) top center / 100% auto repeat-y fixed;
	}
	/* 非封面页：纹理上叠 50% 白底 */
	.detail-site::before {
		content: '';
		position: fixed;
		inset: 0;
		background: rgba(255, 255, 255, 0.5);
		pointer-events: none;
	}

	/* 详情页恢复原生滚动 */
	body:has(.detail-site) { overflow: auto; }

	.detail-site .topbar {
		position: fixed;
		top: calc(48 * var(--u)); /* 与侧边栏 logo 顶部对齐 */
		left: 0;
		right: 0;
		height: calc(32 * var(--u));
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0 calc(56 * var(--u)) 0 calc(390 * var(--u));
		z-index: 40;
	}

	/* 返回：24 号字 + Back 图标，固定不随内容滚动 */
	.back-link {
		display: flex;
		align-items: center;
		gap: calc(12 * var(--u));
		font-size: calc(24 * var(--u));
		color: #333333;
		text-decoration: none;
	}
	.back-link img { display: block; width: calc(24 * var(--u)); height: calc(24 * var(--u)); }
	.back-link:hover span { text-decoration: underline; text-underline-offset: 3px; }

	.lang-switch {
		position: relative;
		display: flex;
		align-items: center;
		gap: calc(10 * var(--u));
		height: calc(24 * var(--u));
	}
	.lang-en { height: calc(17 * var(--u)); }
	.lang-divider { height: calc(24 * var(--u)); }
	.lang-cn { border: 0; background: none; padding: 0; cursor: pointer; opacity: 0.4; transition: opacity 160ms ease; }
	.lang-cn:hover { opacity: 0.8; }
	.lang-cn img { display: block; height: calc(20 * var(--u)); }
	.lang-tip {
		position: absolute;
		top: 130%;
		right: 0;
		background: #333333;
		color: #fff6d7;
		font-size: 12px;
		padding: 4px 10px;
		border-radius: 4px;
		white-space: nowrap;
		opacity: 0;
		pointer-events: none;
		transition: opacity 200ms ease;
	}
	.is-tip-visible .lang-tip { opacity: 1; }

	.menu-button {
		display: none;
		position: fixed;
		top: 20px;
		left: 20px;
		z-index: 70;
		border: 0;
		background: none;
		padding: 8px;
		cursor: pointer;
	}
	.menu-button img { display: block; width: 28px; }

	.detail-main {
		position: relative;
		z-index: 1;
		padding:
			calc(120 * var(--u)) /* 与侧边栏 PI&V 顶部对齐 */
			calc(110 * var(--u))
			calc(100 * var(--u))
			calc(390 * var(--u));
	}

	.detail-heading {
		margin: 0 0 calc(40 * var(--u));
		text-align: right;
		font-size: calc(40 * var(--u));
		font-weight: 700;
		color: #333333;
	}
	.detail-heading a { text-decoration: none; }
	.detail-heading a:hover { text-decoration: underline; }

	.detail-row {
		display: grid;
		grid-template-columns: calc(340 * var(--u)) 1fr;
		column-gap: calc(48 * var(--u));
		margin-bottom: calc(24 * var(--u));
	}
	.detail-row > p {
		grid-column: 2;
		margin: 0;
		font-size: calc(19 * var(--u));
		line-height: 1.55;
		text-align: justify;
		color: #333333;
	}

	.detail-figures {
		grid-column: 1;
		display: flex;
		flex-direction: column;
		gap: calc(20 * var(--u));
	}
	.detail-figures figure { margin: 0; }
	.detail-figures img {
		display: block;
		width: 100%;
		border-radius: 4px;
	}
	.detail-figures figcaption {
		margin-top: calc(6 * var(--u));
		font-size: calc(13 * var(--u));
		color: var(--color-ink-soft);
	}

	.figure-ref { font-style: italic; opacity: 0.75; }

	.placeholder-note { color: var(--color-muted); font-style: italic; }

	/* 窄屏：菜单按钮 + figure 收进文字流，与段落等宽 */
	@media (max-width: 900px) {
		.menu-button { display: block; }
		.detail-site .topbar { padding: 0 20px 0 64px; top: 18px; height: 28px; }
		.back-link { font-size: 16px; gap: 8px; }
		.back-link img { width: 18px; height: 18px; }
		.lang-switch { height: 22px; gap: 8px; }
		.lang-en { height: 15px; }
		.lang-divider { height: 22px; }
		.lang-cn img { height: 18px; }
		.detail-main { padding: 84px 24px 64px; }
		.detail-row { display: flex; flex-direction: column; gap: 16px; }
		.detail-figures { order: 2; }
		.detail-row > p { order: 1; }
		.detail-heading { font-size: 26px; }
	}
</style>

<script>
	document.querySelectorAll('.lang-cn').forEach((button) => {
		button.addEventListener('click', () => {
			const wrap = button.closest('[data-lang-switch]');
			wrap?.classList.add('is-tip-visible');
			window.setTimeout(() => wrap?.classList.remove('is-tip-visible'), 1600);
		});
	});

	document.querySelector('[data-menu-button]')?.addEventListener('click', () => {
		document.body.classList.toggle('menu-open');
	});
</script>
